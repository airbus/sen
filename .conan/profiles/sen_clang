[settings]
os=Linux
arch={{ detect_api.detect_arch() }}
compiler=clang
compiler.cppstd=17
compiler.version=20
build_type=Release

[options]
[tool_requires]
!ninja/*: ninja/[~1]

[buildenv]
CC=clang-20
CXX=clang++-20

[conf]
tools.cmake.cmaketoolchain:generator=Ninja
tools.cmake.cmake_layout:build_folder_vars=['settings.compiler']
