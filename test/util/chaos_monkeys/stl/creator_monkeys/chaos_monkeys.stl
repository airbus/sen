package creator_monkeys;

// sequence of strings to indicate desired objects names to add in sen bus
sequence<string> Strings;

// class in charge of creating the monkeys for the stress tests
class CreatorMonkey
{
  var maxObjectCount      : u32     [static];
  var actionFrameInterval : u32     [static];
  var targetBus           : string  [static];
  var objectsToCreate     : Strings [static];
  var secondsToLive       : f64     [static]; // use negative values for no lifetime limit
  var objectCount         : u32;
  var createdObjectsCount : u64;
  var deletedObjectsCount : u64;
}

enum Activity : u8
{
  none,
  testMethod,
  testMethod2,
  testEvent
}

struct Task
{
  currentActivity : Activity,
  since           : TimeStamp
}

// example class for stress test
class MonkeyTestClass
{
  // properties
  var finishedTasks: u64  [writable];
  var testedEvents:  u64  [writable];
  var currentTask:   Task [writable, confirmed];

  // methods
  fn testMethod(arg1: i32, arg2: string) -> i32;
  fn emitTestEvent();

  // events
  event testEvent(arg1: string, arg2: TimeStamp);
}

// example class for stress test
class MonkeyTestClass2
{
  // properties
  var finishedTasks: u64  [writable];
  var testedEvents:  u64  [writable];
  var currentTask:   Task [writable, confirmed];

  // methods
  fn testMethod(arg1: f64) -> f64;
  fn testMethod2(arg1: u16);
  fn emitTestEvent();

  // events
  event testEvent(arg1: string, arg2: TimeStamp);
}
