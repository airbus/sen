kernel:
  crashReportDisabled: true

load:
  - name: ether
    group: 10
    runDiscoveryHub: 65454
    discovery:
      type: TcpDiscovery
      value:
        beamPeriod: 100 ms
        beamExpiryTime: 1 s
        hubAddress:
          host: sen-hub
          port: 65454

build:
  - name: myComponent
    group: 1
    freqHz: 30
    imports: [object_sync]
    objects:
      - name: publisher
        class: object_sync.PublisherImpl
        numOfListeners: 4
        bus: session.bus
