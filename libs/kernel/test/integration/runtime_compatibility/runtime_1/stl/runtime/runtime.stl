package sen.test.runtime;

sequence<f32> TestSequence;
array<i32, 5> TestArray;

enum TestEnum: u32
{
  elem1,
  elem2,
  elem3,
  elem4,
  elem5
}

struct TestStruct
{
  attr1 : u32,
  attr2 : f64
}

variant TestVariant
{
  f64,
  u32,
  TestStruct
}

quantity<i64, deg> TestQuantity [min: 0, max: 50];

optional<f64> TestOptional;

// Sample class used to test runtime compatibility
class TestClass
{
  // basic types
  var prop1  : u32          [writable];            // i32 in the writer schema
  var prop2  : i32          [writable];            // f32 in the writer schema
  var prop3  : u8           [writable];            // bool in the writer schema
  var prop4  : f32          [writable];            // string in the writer schema

  // sequences
  var prop5  : TestSequence [writable, confirmed]; // bounded sequence of ints in the writer schema
  var prop6  : TestArray    [writable, confirmed]; // array sequence of a u16 with size 6 in the writer

  // enumerations
  var prop7  : TestEnum     [writable];            // different elements/order in the writer schema
  var prop8  : TestEnum     [writable];            // integer in the writer schema
  var prop9  : TestEnum     [writable];            // string in the writer schema

  // structures
  var prop10 : TestStruct   [writable];            // writer struct with different elements/order

  // variant
  var prop11 : TestVariant  [writable];            // writer variant with different types/order

  // quantities
  var prop12 : TestQuantity [writable];            // different quantity in writer schema
  var prop13 : TestQuantity [writable];            // float in writer schema

  // optionals
  var prop14 : TestOptional [writable];            // optional of i32 in the writer schema
  var prop15 : TestOptional [writable];            // u32 in the writer schema

  // methods
  fn testMethod(arg1: i32, arg2: i32, arg3: TestStruct) -> string; // less arguments in the writer schema
  fn extraMethod();                                                // non existent in the writer schema

  fn emitEvents();  // used to command the local TestClass object to emit its events

  // events
  event testEvent(arg1: f64, arg2: TestEnum, arg3: TestVariant);  // less arguments in the writer schema
}
