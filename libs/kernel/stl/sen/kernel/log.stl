package sen.kernel.log;

// Severity/importance of a log message.
enum LogLevel: u8
{
  warn,     // Unexpected behavior or potential issues that do not stop functionality but warrant monitoring.
  err,      // Significant issues that prevent specific functionality from working.
  critical, // Catastrophic failures. The system or a critical element is crashing or unusable.
  trace,    // Extremely detailed, granular information used for debugging, such as function entry/exit points.
  debug,    // Detailed information intended for developers to diagnose problems during development or troubleshooting.
  info,     // Highlights the normal, successful operational path of the application.
  off       // No logs.
}

// stdout sink
struct Stdout {}

// stderr sink
struct Stderr {}

// Colored stdout sink
struct ColorStdout {}

// Colored stderr sink
struct ColorStderr {}

// Basic file sink
struct BasicFile
{
  fileName        : string,  // file to log to
  truncate        : bool,    // defaults to false
  createParentDir : bool     // true if we should create the parent dir first
}

// Rotating file sink
struct RotatingFile
{
  baseFileName : string,
  maxSize      : u32,     // 0 means use defaults
  maxFiles     : u32      // 0 means use defaults
}

// Single-threaded null sink
struct Null {}

// Syslog sink (only in linux)
struct Syslog
{
  identity         : string,
  option           : u32,
  enableFormatting : bool
}

// The type-specific configuration of the used spdlog Sink.
variant SinkType
{
  ColorStdout,
  ColorStderr,
  Stdout,
  Stderr,
  BasicFile,
  RotatingFile,
  Null,
  Syslog
}

// Configuration used for a given spdlog Sink.
struct SinkConfig
{
  name           : string,    // name of the sink
  singleThreaded : bool,      // if true, single-threaded (defaults to false)
  pattern        : string,    // the pattern used for the formatting (empty means default).
  level          : LogLevel,  // default log level for this sink
  config         : SinkType   // the type-specific configuration parameters
}

sequence<string> SinkNameList;

// Configuration used for a given spdlog logger.
struct LoggerConfig
{
  // name of the logger
  name : string,

  // name of the sinks to connect the logger to
  sinks : SinkNameList,

  // default log level for this logger
  level : LogLevel,

  // Formatting for the sinks in this logger. Does nothing if empty.
  // Note that this replaces the format of the associated sinks, and this
  // could affect other loggers using those sinks. The config is applied
  // following the order of the Config.loggers field.
  pattern : string,
}

sequence<SinkConfig> SinkConfigList;
sequence<LoggerConfig> LoggerConfigList;

// Overall component configuration
struct Config
{
  pattern   : string,            // default format (empty means default)
  level     : LogLevel,          // default global level for all
  sinks     : SinkConfigList,    // sinks to configure
  loggers   : LoggerConfigList,  // loggers to configure
  backtrace : bool               // log backtrace is printed on failure
}
