import "stl/sen/components/recorder/configuration.stl"
import "stl/sen/db/basic_types.stl"

package sen.components.recorder;

// the state of a recording session
enum RecorderState: u8
{
  stopped,   // not recording
  recording, // recording
  error      // in some error situation
}

// represents an recording session
class Recorder
{
  var settings    : RecordingSettings  [static];
  var state       : RecorderState      [confirmed];

  // starts (or resumes) recording
  fn start();

  // stops recording
  fn stop();

  // sample the output statistics
  fn fetchStats() -> sen.db.OutStats;
}
