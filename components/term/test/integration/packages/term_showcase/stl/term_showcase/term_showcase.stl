package term_showcase;

// Severity level passed to configure(): exercises the enum cycler editor.
enum Severity: u8
{
  debug,    // verbose, for development
  info,     // the normal baseline
  warning,  // something unexpected but recoverable
  error     // something broken that needs attention
}

// 2D point: exercises the struct editor (two i32 leaves, x and y).
struct Point
{
  x : i32,  // horizontal coordinate
  y : i32   // vertical coordinate
}

// Rectangle: struct of structs, exercises nested struct editing.
struct Rectangle
{
  topLeft     : Point,  // upper-left corner
  bottomRight : Point   // lower-right corner
}

// One-of action: exercises the variant editor (type picker + dynamic subtree).
variant Action
{
  Point,       // the user wants to MOVE to this point
  Rectangle,   // the user wants to DRAW this rectangle
  string,      // the user wants to LOG this message
  i32          // the user wants to WAIT for this many cycles
}

// Named aliases so STL method signatures stay short and readable.
sequence<i32>     IntList;
sequence<Point>   PointList;
optional<f32>     MaybeFloat;
optional<Point>   MaybePoint;

// Bounded meter-valued quantity with integer storage: exercises the quantity editor's
// integer-spin value leaf, unit picker, and clamped range.
quantity<u16, m> Length [min: 0, max: 1000];

// Unit-less floating-point quantity: exercises the quantity editor's fall-back path where the
// field is a plain scalar leaf (no unit to pick).
quantity<f32, f32> Fraction [min: 0.0, max: 1.0];

// Status enum for workers: exercises the enum watch display.
enum WorkerStatus: u8
{
  idle,       // waiting for work
  running,    // executing
  done        // finished, about to be removed
}

// A transient worker object. The Showcase coordinator spawns and removes these dynamically so
// the term's watch pane can exercise disconnected/reconnected states. Each worker ticks its
// own properties while alive.
class Worker
{
  var value : f32;
  var status : WorkerStatus;
  var cycle : u32;

  // Fired each time the worker's status changes: exercises enum args.
  event statusChanged(oldStatus : WorkerStatus, newStatus : WorkerStatus);

  // Fired periodically with no arguments: exercises zero-arg events.
  event heartbeat();

  // Fired with the current position: exercises struct args.
  event positionReported(position : Point);
}

// The showcase class: a single object whose methods collectively exercise every editor the
// term's guided-input form currently supports, plus properties that tick at staggered rates so
// the term's watch pane can be exercised across the full type spectrum.
class Showcase
{
  // --------------------- tickable properties, staggered rates ---------------------
  // Rates are expressed in component cycles (the showcase component ticks at 30 Hz in the
  // reference config, so 30 cycles ≈ 1 second).

  // Monotonic cycle counter: updates every cycle (~33 ms @ 30 Hz), the loudest watch target.
  var ticks : u64;

  // A simulated temperature reading: updates every 10 cycles, oscillates in a sine-like pattern.
  var temperature : f32;

  // Current severity: cycles through the enum every 30 cycles (~1 s).
  var status : Severity;

  // Feature toggle: flips every 90 cycles (~3 s).
  var enabled : bool;

  // Rolling status message: changes every 60 cycles (~2 s).
  var message : string [confirmed];

  // Tracked position: updates every 20 cycles (~0.67 s) along a circular path.
  var position : Point;

  // Trail of recent positions: appends every 50 cycles and trims to the last 8 points.
  // `[confirmed]` because sequences are unbounded by default and the transport needs a reliable
  // mode to avoid dropping samples.
  var trail : PointList [confirmed];

  // Current action: cycles through the variant's alternatives every 120 cycles (~4 s). The
  // variant carries a string alternative so it counts as unbounded; same confirmed requirement.
  var current : Action [confirmed];

  // Target (optional): toggles between (none) and a point every 180 cycles (~6 s).
  var target : MaybePoint;

  // Tracked length: sweeps 0→1000 meters every 40 cycles (~1.3 s).
  var length : Length;

  // A writable counter that methods can nudge: also handy to exercise a property setter.
  var counter : i32 [writable];

  // --------------------- events ---------------------
  // Exercises the listen command with various argument shapes.

  // No arguments: simplest event.
  event tick();

  // Scalar arguments.
  event thresholdCrossed(value : f32, direction : string);

  // Struct argument: exercises composite event args.
  event positionChanged(oldPos : Point, newPos : Point);

  // Variant argument: exercises variant event args.
  event actionPerformed(action : Action);

  // --------------------- worker coordination ---------------------
  // The showcase acts as a coordinator: it periodically spawns and removes Worker objects on
  // the same bus so the term's watch pane can exercise disconnected/reconnected states.

  // How many workers are currently alive.
  var workerCount : u32;

  // Whether the spawn/remove cycle is active. Toggle with setNextSpawning or the form.
  var spawning : bool [writable];

  // --------------------- scalar editors ---------------------

  // Plain text editor: a single string argument.
  fn echo(message : string) -> string [const];

  // Numeric text editors: integer arithmetic.
  // @param a the left operand
  // @param b the right operand
  fn add(a : i32, b : i32) -> i32 [const];

  // Float text editor: the duration shows up as a numeric.
  fn wait(duration : Duration) -> string [const];

  // --------------------- bool + enum editors ---------------------

  // Bool editor (Space or Left/Right to toggle) + enum cycler (Left/Right to cycle).
  fn configure(enabled : bool, level : Severity) -> string [const];

  // --------------------- struct editor ---------------------

  // Simple struct argument.
  fn moveTo(target : Point) -> string [const];

  // Nested struct (struct of structs): tests the renderer's indentation and the leaf walk.
  fn drawRect(area : Rectangle) -> string [const];

  // --------------------- sequence editor ---------------------

  // Sequence of scalars: grow with Ctrl+N, shrink with Ctrl+X.
  fn sumInts(values : IntList) -> i32 [const];

  // Sequence of structs: each element expands into its own x/y leaves.
  fn centroid(points : PointList) -> Point [const];

  // --------------------- variant editor ---------------------

  // Variant argument: cycle the type picker with Left/Right; the value subtree reshapes to
  // match the chosen alternative.
  fn perform(action : Action) -> string [const];

  // --------------------- optional editors ---------------------

  // Optional of scalar: unwrapped by the form, edited as a plain f32 text field. Empty string
  // round-trips as "no value".
  fn setRadius(radius : MaybeFloat) -> string [const];

  // Optional of composite: Ctrl+O toggles between (none) and a default-filled inner struct.
  fn setPosition(position : MaybePoint) -> string [const];

  // --------------------- quantity editors ---------------------

  // Bounded integer quantity with a unit picker: cycle through length units with Left/Right on
  // the unit field; the value field spins in [0, 1000] via Left/Right or direct digit input.
  fn setLength(length : Length) -> string [const];

  // Unit-less floating-point quantity: no unit picker, just a plain float text editor bounded
  // to [0.0, 1.0].
  fn setFraction(fraction : Fraction) -> string [const];
}
