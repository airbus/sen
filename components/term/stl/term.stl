package sen.components.term;

// How timestamps should be displayed
enum TimeStyle: u8
{
  utc,   // use UTC timestamps
  local, // use local time timestamps
}

// Color theme for the terminal UI
enum ThemeStyle: u8
{
  oneDark,         // Atom One Dark
  oneLight,        // Atom One Light
  catppuccinMocha, // Catppuccin Mocha (dark, warm, default)
  catppuccinLatte, // Catppuccin Latte (light, warm)
  dracula,         // Dracula (dark, purple)
  nord,            // Nord (dark, arctic)
  gruvboxDark,     // Gruvbox Dark (warm retro)
  gruvboxLight,    // Gruvbox Light (warm retro)
  tokyoNight,      // Tokyo Night (dark, blue-purple)
  solarizedLight,  // Solarized Light (classic)
}

// Display mode for the terminal component
enum DisplayMode: u8
{
  tui,  // fullscreen TUI with panes, status bar, and keybindings
  repl, // inline REPL, output flows into terminal scroll-back
}

// Holds information about a named query
struct QueryDef
{
  name      : string,  // the name of the query (cannot contain spaces or dots)
  selection : string   // the query expression
}

sequence<string> SourcesList;
sequence<QueryDef> QueryList;
sequence<string> WatchList;

// Configuration params for the term component
struct Configuration
{
  initialScope : string,       // initial scope (e.g. "local.main"). Empty means root.
  timeStyle    : TimeStyle,    // how to display time (default: utc)
  theme        : ThemeStyle,   // color theme (default: catppuccinMocha)
  noLogo       : bool,         // true to suppress the welcome banner
  open         : SourcesList,  // sources to open automatically at startup
  query        : QueryList,    // named queries to create automatically at startup
  watch        : WatchList,    // property watches to register at startup (object or object.property)
  listen       : WatchList,    // event listeners to register at startup (object or object.event)
  callTimeout  : Duration,     // async call timeout (default: 30s)
  logBus       : string,       // where to find the logmaster (default: local.log)
  mode         : DisplayMode   // display mode (default: tui)
}

// Modern TUI-based interactive terminal for the sen kernel
class Term
{
  // service configuration
  var config: Configuration [static];
}
